# Prism Authoring — local environment
# Copy to .env.local and fill in. Never commit .env.local.

# Convex deployment URL (from `npx convex dev`)
VITE_CONVEX_URL=

# Cloudflare Worker (presign endpoint) — points to local wrangler dev or deployed Worker
VITE_WORKER_URL=http://localhost:8787

# ──────────────────────────────────────────────────────────────────────────────
# Convex server-side env vars — set with `npx convex env set KEY value`
# These are NOT stored in .env.local; they live in your Convex deployment.
# ──────────────────────────────────────────────────────────────────────────────
#
# AUTH_SECRET=<run: openssl rand -base64 32>
#
# AUTH_RESEND_KEY=re_xxxxxxxxxxxxxxxxxxxx
#   (from resend.com → API Keys)
#
# AUTH_EMAIL_FROM=Prism Authoring <noreply@yourdomain.com>
#
# SITE_URL=https://your-app.pages.dev
#   (used to build the magic-link URL: ${SITE_URL}/sign-in?code=<token>)
#
# PI_CONVEX_URL=https://your-prism-intelligence.convex.cloud
# PI_API_TOKEN=pi_static_token_here
# PI_COMPANY_CODE=HBPL
# PI_COMPANY_ID=<prism-intelligence-company-document-id>
#   (lets the app accept the human-readable company code while keeping the raw PI id internal)
