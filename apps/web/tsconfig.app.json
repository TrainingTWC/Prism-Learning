{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "outDir": "dist",
    "rootDir": "../../",
    "types": ["vite/client", "node"],
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./src/*"],
      "~convex/*": ["../../convex/*"]
    },
    "noEmit": false
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/test"],
  "references": [{ "path": "../../packages/renderer" }]
}
